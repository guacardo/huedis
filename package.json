{
  "name": "huedis",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "probe": "bun run probe.ts",
    "dev:server": "bun --hot run server/src/index.ts",
    "dev:web": "cd web && bun run dev",
    "dev": "concurrently -n server,web -c blue,magenta 'bun run dev:server' 'bun run dev:web'",
    "start": "bun run server/src/index.ts"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "concurrently": "^9.1.0",
    "typescript": "^5.6.0"
  }
}
